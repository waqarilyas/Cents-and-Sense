{
  "expo": {
    "name": "Budget Planner",
    "slug": "budget-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "budgetplanner",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.budgetplanner.app"
    },
    "android": {
      "package": "com.budgetplanner.app",
      "permissions": ["android.permission.VIBRATE"],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "budgetplanner"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-sqlite"
    ]
  }
}
