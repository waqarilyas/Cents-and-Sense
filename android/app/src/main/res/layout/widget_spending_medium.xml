<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/budget_overview"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_tertiary"/>

        <TextView
            android:id="@+id/budget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On Track"
            android:textSize="11sp"
            android:textColor="@color/widget_success"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/status_badge"/>
    </LinearLayout>

    <!-- Budget Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/spending_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"/>

            <TextView
                android:id="@+id/budget_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / $0.00"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="3dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/remaining_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00 remaining this month"
            android:textSize="13sp"
            android:textColor="@color/widget_success"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/budget_progress"
        style="?android:progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginBottom="14dp"
        android:progressDrawable="@drawable/progress_bar"/>

    <!-- Stats Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/stat_card">

            <TextView
                android:id="@+id/daily_avg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="16sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Average"
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/stat_card">

            <TextView
                android:id="@+id/days_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 days"
                android:textSize="16sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Left in Month"
                android:textSize="10sp"
                android:textColor="@color/widget_text_secondary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Top Category -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/category_card"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Spending"
            android:textSize="10sp"
            android:textColor="@color/widget_text_secondary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/category1_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="15sp"
                    android:textColor="@color/widget_text_primary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/category1_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% of budget"
                    android:textSize="11sp"
                    android:textColor="@color/widget_text_tertiary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/category1_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="17sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Quick Add Button -->
    <Button
        android:id="@+id/quick_add_button"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:text="+ Quick Add Expense"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/button_background"
        android:textColor="#FFFFFF"/>
</LinearLayout>
